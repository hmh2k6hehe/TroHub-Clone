{
  "name": "trohub-web-only",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "TroHub web admin with a local API and optional MongoDB storage.",
  "scripts": {
    "dev": "concurrently \"npx http-server . -p 5173 -a 127.0.0.1\" \"cd API_DuAnTotNghiep && npm start\"",
    "web": "npx http-server . -p 5173 -a 127.0.0.1",
    "api": "cd API_DuAnTotNghiep && npm start",
    "start": "npm run dev"
  },
  "keywords": [
    "trohub",
    "web-admin",
    "room-rental",
    "vanilla-js"
  ],
  "license": "MIT",
  "optionalDependencies": {
    "mongodb": "^6.20.0"
  },
  "dependencies": {
    "acorn": "^8.17.0",
    "concurrently": "^9.1.2"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  }
}
